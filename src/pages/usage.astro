---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

// Walkthroughs in the order a new user meets them: set up, look around,
// configure, collaborate, watch work happen, verify it, make it yours.
const walkthroughs = [
  {
    id: 'getting-started',
    title: 'Getting started',
    video: 'onboarding.mp4',
    body: 'Run the setup wizard once and Orcha builds your team for you — name yourself, describe your goal, and it proposes a roster of agents you review and create.',
  },
  {
    id: 'dashboard',
    title: 'Your dashboard',
    video: 'dashboard.mp4',
    body: 'Your home base. See what needs your attention, the agents on the job and the models they run on, and the whole task board at a glance.',
  },
  {
    id: 'autonomy',
    title: 'Setting the autonomy level',
    video: 'autonomy.mp4',
    body: 'Decide how far agents can go on their own — from plan-only, to building up to a pull request, to full autonomy — with a clear confirmation before each change.',
  },
  {
    id: 'model-selection',
    title: 'Choosing each agent’s model',
    video: 'model-selection.mp4',
    body: 'Give every agent the right brain for its job. Pick the AI model per agent in a couple of clicks.',
  },
  {
    id: 'conversation',
    title: 'Talking to an agent',
    video: 'conversation.mp4',
    body: 'Chat with an agent directly, and attach files or images when a screenshot or document says it better than words.',
  },
  {
    id: 'requests',
    title: 'Agents working together',
    video: 'requests.mp4',
    body: 'Agents ask each other — and you — for what they need through requests and task threads, so nothing happens in the dark.',
  },
  {
    id: 'worker-runs',
    title: 'Watching a worker run',
    video: 'worker-runs.mp4',
    body: 'Follow an agent live as it works — narration, the tools it calls, the results it gets, and a status badge when each run finishes.',
  },
  {
    id: 'verification',
    title: 'Verifying plans and work',
    video: 'verification.mp4',
    body: 'You stay in charge. Approve a plan before work starts, and verify the finished result before a task is marked complete.',
  },
  {
    id: 'theme',
    title: 'Light and dark themes',
    video: 'theme.mp4',
    body: 'Make it yours — flip the whole portal between dark and light whenever you like.',
  },
];

// The handful of ways your agents talk to each other and to you. Each card pairs
// a plain-English definition with the moment you'd actually reach for it.
const concepts = [
  {
    icon: '💬',
    title: 'Conversation',
    body: 'A direct, free-form chat with a single agent — like messaging a teammate. Ask questions, give quick direction, or attach a file or screenshot. Nothing is assigned or tracked as a deliverable; it’s just talking.',
    when: 'when you want to talk to one agent, with no work item attached.',
  },
  {
    icon: '✉️',
    title: 'Request',
    body: 'A tracked message from one agent (or you) to another that expects a reply. Two kinds: an info request asks a question (the other side answers it), and a task request asks for work (the other side accepts it — which creates a Task — or declines). Every request has a clear lifecycle, so a hand-off never gets lost.',
    when: 'when one agent needs something from another and you want a record of the ask and the reply.',
  },
  {
    icon: '📋',
    title: 'Task',
    body: 'A unit of work assigned to one agent, with a clear definition of done. It moves from ready, to in-progress, to needs-verification, to completed. The key rule: an agent’s work stops at needs-verification — a human signs off before it’s truly done.',
    when: 'when there is real work to deliver and verify.',
  },
  {
    icon: '🧭',
    title: 'Task Protocol',
    body: 'The standing playbook attached to a task — the steps an agent re-reads every turn while working on it. This is where you encode a repeatable process, including loops like “if the review isn’t clean, fix it and ask again.”',
    when: 'when you want an agent to follow a set procedure on its own, without you driving each step.',
  },
  {
    icon: '🧵',
    title: 'Task Thread',
    body: 'The running comment log on a task, where agents and people post updates, questions and decisions in order. It’s the task’s shared memory and its audit trail.',
    when: 'when you want to discuss or record something in the context of one specific task.',
  },
];

// A small, self-running workflow built from the pieces above: one agent opens a
// PR, another reviews it, they loop until it’s clean, then it lands on you.
const recipe = [
  {
    h: 'Create one task for the builder',
    p: 'Give Agent A a single task named for the outcome — e.g. “Implement X and land a clean PR.” Set its definition of done: the PR is open, has passed the reviewer’s check with zero outstanding comments, and has been handed to you.',
  },
  {
    h: 'Write the loop into the task’s Protocol',
    p: 'Spell out the steps Agent A re-reads each turn: (1) do the work and open the PR; (2) send a task request to Agent B — “review PR #N and send findings back to me”; (3) when the review returns, fix any issues and go back to step 2, or if it’s clean move on; (4) mark the task done. That “go back to step 2” line is the loop.',
  },
  {
    h: 'Let the baton pass on its own',
    p: 'Each hand-off is a Request with a built-in round trip: Agent A’s task request wakes Agent B; B reviews and answers, which automatically returns the result to A. You don’t wire any of this up — the agents just follow the Protocol.',
  },
  {
    h: 'Add a runaway guard',
    p: 'One more Protocol line keeps a stubborn review from ping-ponging forever: “If the PR isn’t clean after 5 review rounds, stop and escalate to the human with what’s stuck.”',
  },
  {
    h: 'You approve at the end',
    p: 'When Agent A marks the task done, it moves to needs-verification — your approval gate. Verify it to complete the task, or send it back with feedback to reopen it. That’s the only step that needs you.',
  },
];
---
<Base title="Usage Guide — Orcha" description="A visual walkthrough of running Orcha day to day — setup, dashboard, autonomy, agent collaboration, worker runs and verification.">
  <!-- INTRO -->
  <section class="usage-intro">
    <div class="wrap">
      <h1>Usage Guide</h1>
      <p class="section-sub">
        A visual tour of running Orcha day to day — from first-time setup to reviewing and
        verifying finished work. Each short clip walks through one part of the portal.
      </p>
    </div>
  </section>

  <!-- WALKTHROUGHS -->
  {walkthroughs.map((w, i) => (
    <section id={w.id} class="walk">
      <div class="wrap walk-inner">
        <div class="walk-copy">
          <p class="walk-num">{String(i + 1).padStart(2, '0')}</p>
          <h2 class="section-title">{w.title}</h2>
          <p class="walk-body">{w.body}</p>
        </div>
        <figure class="walk-media">
          <video
            src={`${base}guide/${w.video}`}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-label={w.title}
          ></video>
        </figure>
      </div>
    </section>
  ))}

  <!-- COLLABORATION MODEL -->
  <section id="building-blocks" class="concepts">
    <div class="wrap">
      <h2 class="section-title">The building blocks: how agents and people work together</h2>
      <p class="section-sub">
        Orcha gives your team a few simple ways to talk — to each other and to you. Here’s each
        one in plain terms, and the moment you’d reach for it. Across all of them you stay in
        charge: agents hand work back to you to verify, and can escalate a question to you any time.
      </p>
      <div class="grid">
        {concepts.map((c) => (
          <article class="card">
            <div class="ico" aria-hidden="true">{c.icon}</div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
            <p class="when"><span>When to use it —</span> {c.when}</p>
          </article>
        ))}
      </div>
      <figure class="collab-media">
        <video
          src={`${base}guide/building-blocks.mp4`}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="Agents and a human collaborating in a task thread"
        ></video>
        <figcaption>Agents and a person working together in a task thread — comments, hand-offs and verification in one place.</figcaption>
      </figure>
    </div>
  </section>

  <!-- WORKED EXAMPLE: PR + REVIEW LOOP -->
  <section id="pr-review-loop" class="recipe">
    <div class="wrap">
      <h2 class="section-title">A worked example: a self-running PR &amp; review loop</h2>
      <p class="section-sub">
        Here’s how those pieces snap together into a small workflow that runs itself. The goal: one
        agent builds a feature and opens a pull request, a second agent reviews it, they cycle until
        it’s clean, then it lands on your desk to approve. You set it up once and walk away — the
        loop lives in the task’s Protocol, and Requests carry the baton between the agents.
      </p>
      <div class="steps">
        {recipe.map((s, i) => (
          <div class="step">
            <div class="num">{i + 1}</div>
            <h4>{s.h}</h4>
            <p>{s.p}</p>
          </div>
        ))}
      </div>
      <figure class="collab-media">
        <video
          src={`${base}guide/pr-review-loop.mp4`}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label="A PR and review loop running between two agents via requests"
        ></video>
        <figcaption>Requests carry the baton: one agent asks another to review the PR, the answer comes straight back, and the loop turns until it’s clean.</figcaption>
      </figure>
      <p class="recipe-foot">
        Two ways to escalate to you: to hand finished work up for approval, an agent marks its task
        done so it reaches needs-verification — your sign-off gate. If an agent gets stuck mid-loop
        and needs you, it escalates a request straight to you instead.
      </p>
    </div>
  </section>

  <!-- OUTRO -->
  <section class="usage-outro">
    <div class="wrap">
      <p class="section-sub">Ready to try it on your own project?</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={`${base}installation`}>Get Orcha</a>
        <a class="btn btn-ghost" href={base}>Back home</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .usage-intro { padding-bottom: 16px; }
  .usage-intro h1 { font-size: clamp(2rem, 5vw, 2.8rem); margin: 0 0 12px; letter-spacing: -0.02em; }

  .walk { padding: 40px 0; border-top: 1px solid var(--line); }
  .walk-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 40px;
    align-items: center;
  }
  /* Alternate sides for visual rhythm */
  .walk:nth-child(even) .walk-copy { order: 2; }
  .walk:nth-child(even) .walk-media { order: 1; }

  .walk-num {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--cyan);
    margin: 0 0 10px;
    letter-spacing: 0.08em;
  }
  .walk-body { color: var(--muted); margin: 0; font-size: 1.02rem; line-height: 1.6; }
  .walk .section-title { margin: 0 0 12px; }

  .walk-media { margin: 0; }
  .walk-media video {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--deep);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }

  .collab-media {
    margin: 36px auto 0;
    max-width: 920px;
  }
  .collab-media video {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--deep);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }
  .collab-media figcaption {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
    text-align: center;
  }

  .concepts, .recipe { padding: 48px 0; border-top: 1px solid var(--line); }
  .concepts .card .when {
    margin: 14px 0 0;
    font-size: 0.9rem;
    color: var(--foam);
  }
  .concepts .card .when span {
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--cyan);
  }
  .recipe-foot {
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.6;
    max-width: 760px;
  }

  .usage-outro { text-align: center; border-top: 1px solid var(--line); }
  .usage-outro .section-sub { margin: 0 auto 24px; }

  @media (max-width: 760px) {
    .walk-inner { grid-template-columns: 1fr; gap: 20px; }
    .walk:nth-child(even) .walk-copy { order: 1; }
    .walk:nth-child(even) .walk-media { order: 2; }
  }
</style>
