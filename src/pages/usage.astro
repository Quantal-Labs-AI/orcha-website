---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="Usage Guide — Orcha" description="How to use Orcha day to day. Coming soon.">
  <section class="coming">
    <div class="wrap">
      <p class="badge">Coming soon</p>
      <h1>Usage Guide</h1>
      <p>
        A practical guide to running Orcha day to day — registering agents, assigning objectives,
        reviewing work and verifying results — is being written. Check back shortly.
      </p>
      <div class="cta-row">
        <a class="btn btn-ghost" href={base}>Back home</a>
      </div>
    </div>
  </section>
</Base>
