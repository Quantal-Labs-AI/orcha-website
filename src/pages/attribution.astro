---
import Base from '../layouts/Base.astro';
import { REPO } from '../consts.js';
const base = import.meta.env.BASE_URL;
---
<Base title="Open Source Attribution — Orcha" description="Open source licenses and attribution for Orcha. Coming soon.">
  <section class="coming">
    <div class="wrap">
      <p class="badge">Coming soon</p>
      <h1>Open Source Attribution</h1>
      <p>
        Orcha stands on a lot of open source. A full list of the projects, licenses and
        acknowledgements that make it possible will be published here.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={REPO} target="_blank" rel="noopener">Browse the source ↗</a>
        <a class="btn btn-ghost" href={base}>Back home</a>
      </div>
    </div>
  </section>
</Base>
